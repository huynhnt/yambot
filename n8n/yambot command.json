    {
      "parameters": {
        "jsCode": "const text = $input.first().json.message.text;\nconst chat_id = $input.first().json.message.chat.id;\nconst match = text.match(/\\/remove_?(\\d+)/);\n\nif (!match) {\n  return { json: { error: true, chat_id, text: \"⚠️ <b>Sai cú pháp!</b>\\nHãy gõ /list và bấm vào nút xoá tương ứng.\" } };\n}\n\nconst id = parseInt(match[1], 10);\nreturn { json: { id, chat_id, error: false } };"
      },
