        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"site\": \"{{ $json.site }}\",\n  \"keyword\": \"{{ $json.keyword }}\",\n  \"min_price\": {{ $json.min_price || \"null\" }},\n  \"max_price\": {{ $json.max_price || \"null\" }},\n  \"exclude_keyword\": {{ $json.exclude_keyword ? `\"${$json.exclude_keyword}\"` : \"null\" }},\n  \"category_id\": {{ $json.category_id ? JSON.stringify($json.category_id) : \"null\" }},\n  \"item_condition_id\": {{ $json.item_condition_id ? JSON.stringify($json.item_condition_id) : \"null\" }},\n  \"level\": {{ $json.level || \"null\" }},\n  \"supplement\": {{ $json.supplement ? `\"${$json.supplement}\"` : \"null\" }}\n}\n",
        "options": {}
      },
      "id": "2905666a-af30-4b98-86b3-b512ff1acd7e",
      "name": "POST /configs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        400,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const chat_id = $('Parse Add').item.json.chat_id;\nconst data = $input.first().json;\nconst entry = data.entry;\n\nlet msg = `✅ <b>Đã thêm thành công!</b>\\n`;\nmsg += `ID: ${entry.id}\\nSite: ${entry.site.toUpperCase()}\\nTừ khoá: <b>${entry.keyword || entry.va}</b>\\n`;\n\n// Chỉ hiện thị các dòng này nếu bạn có cấu hình\nif (entry.price_min || entry.min) msg += `🔹 Giá Min: ${entry.price_min || entry.min}\\n`;\nif (entry.price_max || entry.max) msg += `🔹 Giá Max: ${entry.price_max || entry.max}\\n`;\nif (entry.exclude_keyword || entry.ve) msg += `🔹 Loại trừ: ${entry.exclude_keyword || entry.ve}\\n`;\n\nmsg += `\\n👉 Gõ /list để kiểm tra.`;\nreturn { json: { chat_id, text: msg } };\n"
      },
      "id": "bbef7677-d2f3-4098-80bc-55bf0d06edfb",
      "name": "Format Add",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        384
