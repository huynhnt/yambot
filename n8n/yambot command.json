      "parameters": {
        "jsCode": "const text = $input.first().json.message.text;\nconst chat_id = $input.first().json.message.chat.id;\nconst match = text.match(/\\/exclude_?([a-zA-Z0-9_-]+)/);\n\nif (!match) {\n  return { json: { error: true, chat_id, text: \"⚠️ <b>Sai cú pháp!</b>\\nMã sản phẩm không hợp lệ.\" } };\n}\n\nconst item_id = match[1];\nreturn { json: { item_id, chat_id, error: false } };"
      },
