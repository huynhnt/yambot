    },
    {
      "parameters": {
        "jsCode": "const chat_id = $input.first().json.message.chat.id;\nconst msg = `👋 <b>Chào mừng bạn đến với Yambot!</b>\\n\\n📋 <b>Danh sách lệnh:</b>\\n/list - Xem danh sách đang theo dõi\\n/add - Thêm từ khoá mới\\n/help - Xem lại tin nhắn này\\n\\n💡 <i>Mẹo thêm nâng cao:</i>\\nCú pháp: <code>/add [site] [từ khoá] -min [giá] -max [giá] -ex [từ loại trừ] -cat [mã] -cond [mã] -lv [1-3] -sup [từ phụ]</code>\\nVD: <code>/add mercari iphone 15 -min 1000 -max 50000 -ex hỏng -cat 75 -cond 1,2 -lv 3 -sup apple</code>\\n\\n📝 <b>Hướng dẫn (Mercari):</b>\\n<b>-lv (Level)</b>\\n1: Track tất cả\\n2: Tên sp phải có từ khoá\\n3: (Cần thêm -sup) Tên sp phải có từ khoá\\n\\n<b>-cat (Category)</b>\\nCD: 75\\nBluray: 9888\\n\\n<b>-cond (Condition)</b>\\n1: Mới tinh\\n2: Gần như mới\\n3: Không xước rõ\\n4: Xước nhẹ\\n5: Xước bẩn rõ\\n6: Rất tệ\\n\\n📝 <b>Hướng dẫn (Yahoo Auctions):</b>\\n<b>-cat (Category)</b>\\nMusic: 22152\\nCD: 22192\\n\\n<b>-cond (Condition)</b>\\n1: Mới tinh\\n2: Cũ nói chung\\n3: Gần như mới\\n4: Không xước rõ\\n5: Xước nhẹ\\n6: Xước bẩn rõ\\n7: Rất tệ`;\nreturn { json: { chat_id, text: msg } };\n"
      },
      "id": "887ed4af-6440-4fe0-88e0-a1877f1ab56f",
      "name": "Format Help",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "url": "http://yambot-api:8080/configs",
        "options": {}
      },
      "id": "0993c905-1627-4762-80ff-57e3ab6002f6",
      "name": "GET /configs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        0,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst chat_id = $('Telegram Trigger').item.json.message.chat.id;\nlet msg = '📋 <b>Danh sách theo dõi:</b>\\n\\n';\n\nif (data.configs && data.configs.length > 0) {\n  data.configs.forEach(c => {\n    const kw = c.keyword || c.va || 'N/A';\n    msg += `🔸 <b>[${c.site.toUpperCase()}]</b> ${kw}\\n`;\n    msg += `👉 Nhấn để xoá: /remove_${c.id}\\n\\n`;\n  });\n} else {\n  msg += 'Chưa có cấu hình nào. Hãy dùng lệnh /add để thêm mới.';\n}\nreturn { json: { chat_id, text: msg } };"
      },
      "id": "a3dddd93-cf9e-4126-ab44-d475d2be3f98",
      "name": "Format List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.message.text;\nconst chat_id = $input.first().json.message.chat.id;\nconst parts = text.split(' ');\n\nif (parts.length < 3) {\n  return { json: { error: true, chat_id, text: \"⚠️ <b>Sai cú pháp!</b>\\nHD: <code>/add [site] [từ khoá] -min [giá] -max [giá] -ex [từ loại trừ] -cat [mã,mã] -cond [mã,mã] -lv [1/2/3] -sup [từ phụ]</code>\\n👉 Dùng lệnh /help để xem hướng dẫn chi tiết các mã danh mục và tình trạng.\" } };\n}\n\nlet site = parts[1].toLowerCase();\nif (site === 'yahoo') site = 'yahoo_auctions';\n\nlet restText = parts.slice(2).join(' ');\nlet keyword = restText;\nlet min_price = null, max_price = null, exclude_keyword = null;\nlet category_id = null, item_condition_id = null, level = 1, supplement = null;\n\nconst minMatch = restText.match(/-min\\s+(\\d+)/);\nif (minMatch) {\n    min_price = parseInt(minMatch[1], 10);\n    keyword = keyword.replace(minMatch[0], '');\n}\n\nconst maxMatch = restText.match(/-max\\s+(\\d+)/);\nif (maxMatch) {\n    max_price = parseInt(maxMatch[1], 10);\n    keyword = keyword.replace(maxMatch[0], '');\n}\n\nconst catMatch = restText.match(/-cat\\s+([\\d,]+)/);\nif (catMatch) {\n    category_id = catMatch[1].split(',').map(Number);\n    keyword = keyword.replace(catMatch[0], '');\n}\n\nconst condMatch = restText.match(/-cond\\s+([\\d,]+)/);\nif (condMatch) {\n    item_condition_id = condMatch[1].split(',').map(Number);\n    keyword = keyword.replace(condMatch[0], '');\n}\n\nconst lvMatch = restText.match(/-lv\\s+(\\d)/);\nif (lvMatch) {\n    level = parseInt(lvMatch[1], 10);\n    keyword = keyword.replace(lvMatch[0], '');\n}\n\nconst supMatch = restText.match(/-sup\\s+([^-\\n]+)/);\nif (supMatch) {\n    supplement = supMatch[1].trim();\n    keyword = keyword.replace(supMatch[0], '');\n}\n\nconst exMatch = restText.match(/-ex\\s+([^-\\n]+)/);\nif (exMatch) {\n    exclude_keyword = exMatch[1].trim();\n    keyword = keyword.replace(exMatch[0], '');\n}\n\nkeyword = keyword.trim();\n\nreturn { json: { site, keyword, min_price, max_price, exclude_keyword, category_id, item_condition_id, level, supplement, chat_id, error: false } };\n"
      },
